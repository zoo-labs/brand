{
  "name": "@zooai/brand",
  "version": "1.2.0",
  "description": "Official brand assets and design system for Zoo",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./brand.json": "./brand.json",
    "./loader": {
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    },
    "./assets/*": "./assets/*",
    "./styles/*": "./styles/*"
  },
  "files": [
    "dist",
    "assets",
    "fonts",
    "styles",
    "brand.json",
    "translations"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "zoo",
    "brand",
    "design-system",
    "ui",
    "assets",
    "logo",
    "colors",
    "typography"
  ],
  "author": "Zoo NGO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zooai/brand"
  },
  "homepage": "https://github.com/zooai/brand",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}